{
  "entities": {
    "product": {
      "title": "Product",
      "description": "Store handmade jewellery product entry details",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "nameKO": { "type": "string" },
        "nameEN": { "type": "string" },
        "nameJP": { "type": "string" },
        "category": { "type": "string" },
        "descriptionKO": { "type": "string" },
        "descriptionEN": { "type": "string" },
        "descriptionJP": { "type": "string" },
        "defaultImage": { "type": "string" },
        "materialKO": { "type": "string" },
        "materialEN": { "type": "string" },
        "materialJP": { "type": "string" },
        "price": { "type": "number" },
        "options": { "type": "object" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "nameKO", "nameEN", "nameJP", "category", "price", "defaultImage"]
    },
    "category": {
      "title": "Category",
      "description": "Store main navigation and custom category attributes",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "categoryImageUrl": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "categoryImageUrl"]
    }
  },
  "firestore": {
    "products": {
      "schema": "product",
      "description": "Jewellery products database list"
    },
    "categories": {
      "schema": "category",
      "description": "Collection details and category cover images"
    }
  }
}
