rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /products/{allPaths=**} {
      // Anyone can view product images (Requirement #6)
      allow read: if true;
      
      // Only the admin authenticated with email lch200048@gmail.com can write/modify/delete (Requirement #6)
      allow write: if request.auth != null && request.auth.token.email == 'lch200048@gmail.com';
    }
    
    // Fallback match for any other files/folders
    match /{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.email == 'lch200048@gmail.com';
    }
  }
}
